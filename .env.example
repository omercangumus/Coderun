# ========================
# Veritabanı
# ========================

# PostgreSQL bağlantı URL'i (asyncpg sürücüsü ile)
# Örnek: postgresql+asyncpg://kullanici:sifre@localhost:5432/veritabani
DATABASE_URL=

# Redis bağlantı URL'i
# Örnek: redis://localhost:6379/0
REDIS_URL=

# ========================
# Güvenlik / JWT
# ========================

# JWT imzalama için gizli anahtar (en az 32 karakter, rastgele üretilmeli)
# Üretmek için: openssl rand -hex 32 veya python -c "import secrets; print(secrets.token_hex(32))"
# ÖNEMLİ: Production'da mutlaka güvenli bir key kullanın ve asla commit etmeyin!
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32

# JWT imzalama algoritması
ALGORITHM=HS256

# Access token geçerlilik süresi (dakika)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token geçerlilik süresi (gün)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================
# AI / Ollama
# ========================

# Ollama servisinin URL'i
# Örnek: http://localhost:11434
OLLAMA_URL=

# ========================
# Uygulama
# ========================

# Çalışma ortamı: development | staging | production
ENVIRONMENT=development

# CORS için izin verilen origin'ler (JSON array formatında)
# Development için tüm origin'lere izin: "*"
# Production için spesifik origin'ler: '["https://coderun.app","https://www.coderun.app"]'
# Mobile app için Android emulator (10.0.2.2) ve iOS simulator (localhost) adresleri dahil edin
# Örnek: '["http://localhost:3000","http://10.0.2.2:8000","http://localhost:8081"]'
ALLOWED_ORIGINS=http://localhost:3000

# Uygulama başlığı (OpenAPI dokümantasyonunda görünür)
APP_TITLE=Coderun API

# Uygulama sürümü
APP_VERSION=0.1.0

# ========================
# PostgreSQL (Docker Compose)
# ========================

# PostgreSQL kullanıcı adı
POSTGRES_USER=

# PostgreSQL şifresi
POSTGRES_PASSWORD=

# PostgreSQL veritabanı adı
POSTGRES_DB=
